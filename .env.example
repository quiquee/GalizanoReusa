# Galizano Reusa - Variables de entorno
# Copia este archivo a .env y rellena los valores

# Base de datos
DATABASE_URL="file:./dev.db"

# Servidor
PORT=4001
NODE_ENV=development
BASE_URL=http://localhost:4001

# Sesión
SESSION_SECRET=cambia-esto-por-un-secreto-seguro-aleatorio

# Stripe (obtener en https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
