<div class="max-w-md mx-auto text-center py-16">
  <div class="text-6xl mb-4"><%= code === 404 ? '🔍' : '⚠️' %></div>
  <h1 class="text-3xl font-bold text-mar-oscuro mb-2"><%= t('error.title', { code: code }) %></h1>
  <p class="text-gray-600 mb-6"><%= message %></p>
  <a href="/" class="bg-mar text-white px-4 py-2 rounded-lg hover:bg-mar-oscuro transition text-sm">
    <%= t('error.backHome') %>
  </a>
</div>
