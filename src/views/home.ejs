<!-- Hero Banner -->
<div class="relative w-screen left-1/2 -translate-x-1/2 max-h-[33vh] overflow-hidden -mt-8 mb-8">
  <img src="/images/hero-playa.jpg" alt="<%= t('brand') %>"
    class="w-full h-[33vh] object-cover object-center">
  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
  <div class="absolute bottom-4 left-0 right-0 text-center text-white px-4">
    <div class="flex items-center justify-center gap-3">
      <img src="/images/GalizanoReusa-Icon.jpeg" alt="<%= t('brand') %>" class="w-10 h-10 rounded-full object-cover shadow-lg">
      <h1 class="text-3xl md:text-4xl font-bold drop-shadow-lg"><%= t('brand') %></h1>
    </div>
    <p class="text-sm md:text-base mt-1 drop-shadow-md"><%= t('heroSubtitle') %></p>
  </div>
</div>

<section class="text-center">
  <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
    <%= t('heroDesc') %>
  </p>
 
  <div class="grid gap-6 mt-12 <%= user ? 'md:grid-cols-2' : 'md:grid-cols-3' %>">
    <!-- Para Ofertantes -->
    <div class="bg-white rounded-2xl shadow-md p-6 text-left">
      <div class="text-3xl mb-3">📦</div>
      <h3 class="font-semibold text-lg text-mar-oscuro mb-2"><%= t('home.shareTitle') %></h3>
      <p class="text-gray-600 text-sm mb-4"><%= t('home.shareDesc') %></p>
      <% if (user && (user.role === 'ofertante' || user.role === 'admin')) { %>
        <a href="/items/crear" class="text-mar font-medium hover:underline text-sm"><%= t('home.addItem') %></a>
      <% } else if (user && user.role === 'cliente') { %>
        <a href="/auth/registro-ofertante" class="text-mar font-medium hover:underline text-sm"><%= t('home.becomeOfertante') %></a>
      <% } else { %>
        <a href="/auth/registro-ofertante" class="text-mar font-medium hover:underline text-sm"><%= t('home.registerOfertante') %></a>
      <% } %>
    </div>

    <!-- Para Clientes -->
    <div class="bg-white rounded-2xl shadow-md p-6 text-left">
      <div class="text-3xl mb-3">📱</div>
      <h3 class="font-semibold text-lg text-mar-oscuro mb-2"><%= t('home.scanTitle') %></h3>
      <p class="text-gray-600 text-sm mb-4"><%= t('home.scanDesc') %></p>
      <% if (user) { %>
        <a href="/catalogo" class="text-mar font-medium hover:underline text-sm"><%= t('home.viewItems') %></a>
      <% } else { %>
        <a href="/auth/registro-cliente" class="text-mar font-medium hover:underline text-sm"><%= t('home.registerNoDeposit') %></a>
      <% } %>
    </div>

    <% if (!user) { %>
    <!-- Sin registro (solo para visitantes) -->
    <div class="bg-white rounded-2xl shadow-md p-6 text-left">
      <div class="text-3xl mb-3">⚡</div>
      <h3 class="font-semibold text-lg text-mar-oscuro mb-2"><%= t('home.immediateTitle') %></h3>
      <p class="text-gray-600 text-sm mb-4"><%= t('home.immediateDesc') %></p>
      <a href="/catalogo" class="text-mar font-medium hover:underline text-sm"><%= t('home.viewItems') %></a>
    </div>
    <% } %>
  </div>
</section>

<!-- Cómo funciona -->
<section class="mt-16">
  <h2 class="text-2xl font-bold text-mar-oscuro text-center mb-8"><%= t('home.howTitle') %></h2>
  <div class="grid md:grid-cols-4 gap-4">
    <div class="text-center">
      <div class="bg-mar/10 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-3 text-2xl">1</div>
      <h4 class="font-medium text-sm"><%= t('home.step1Title') %></h4>
      <p class="text-xs text-gray-500 mt-1"><%= t('home.step1Desc') %></p>
    </div>
    <div class="text-center">
      <div class="bg-mar/10 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-3 text-2xl">2</div>
      <h4 class="font-medium text-sm"><%= t('home.step2Title') %></h4>
      <p class="text-xs text-gray-500 mt-1"><%= t('home.step2Desc') %></p>
    </div>
    <div class="text-center">
      <div class="bg-mar/10 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-3 text-2xl">3</div>
      <h4 class="font-medium text-sm"><%= t('home.step3Title') %></h4>
      <p class="text-xs text-gray-500 mt-1"><%= t('home.step3Desc') %></p>
    </div>
    <div class="text-center">
      <div class="bg-mar/10 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-3 text-2xl">4</div>
      <h4 class="font-medium text-sm"><%= t('home.step4Title') %></h4>
      <p class="text-xs text-gray-500 mt-1"><%= t('home.step4Desc') %></p>
    </div>
  </div>
</section>
