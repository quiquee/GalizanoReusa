<!DOCTYPE html>
<html lang="<%= lng %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= t('brand') %></title>
  <link rel="icon" type="image/jpeg" href="/images/GalizanoReusa-Icon.jpeg">
  <link rel="apple-touch-icon" href="/images/GalizanoReusa-Icon.jpeg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-b from-sky-100 to-arena">
  <!-- Minimal header for landing pages -->
  <header class="bg-white/80 backdrop-blur shadow-sm py-3 px-4 text-center">
    <a href="/" class="text-mar-oscuro font-bold text-lg">🌊 <%= t('brand') %></a>
  </header>

  <!-- Flash messages -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="max-w-lg mx-auto mt-4 px-4">
      <div class="bg-green-50 border border-green-300 text-green-800 px-4 py-3 rounded-lg text-sm">
        <%= success %>
      </div>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="max-w-lg mx-auto mt-4 px-4">
      <div class="bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-lg text-sm">
        <%= error %>
      </div>
    </div>
  <% } %>

  <main class="max-w-lg mx-auto px-4 py-6">
    <%- body %>
  </main>

  <footer class="text-center text-xs text-gray-400 py-4">
    <%= t('footer.circularEconomy') %>
  </footer>
</body>
</html>
