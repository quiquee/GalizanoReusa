<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Galizano Reusa</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            arena: '#f5e6d3',
            mar: '#0077b6',
            'mar-oscuro': '#023e8a',
            coral: '#ff6b6b',
            verde: '#2d6a4f',
          }
        }
      }
    }
  </script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-b from-sky-50 to-arena flex flex-col">
  <!-- Navbar -->
  <nav class="bg-white/90 backdrop-blur shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-mar-oscuro font-bold text-xl">
        🌊 Galizano Reusa
      </a>
      <div class="flex items-center gap-4 text-sm">
        <% if (user) { %>
          <span class="text-gray-600">Hola, <strong><%= user.nombre %></strong></span>
          <% if (user.role === 'ofertante' || user.role === 'admin') { %>
            <a href="/dashboard" class="text-mar hover:underline">Mi Panel</a>
            <a href="/items/crear" class="bg-mar text-white px-3 py-1.5 rounded-lg hover:bg-mar-oscuro transition">+ Añadir objeto</a>
          <% } %>
          <a href="/auth/logout" class="text-gray-500 hover:text-coral transition">Salir</a>
        <% } else { %>
          <a href="/auth/login" class="text-mar hover:underline">Iniciar sesión</a>
          <a href="/auth/registro-cliente" class="bg-mar text-white px-3 py-1.5 rounded-lg hover:bg-mar-oscuro transition">Registrarse</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Flash messages -->
  <% if (success && success.length > 0) { %>
    <div class="max-w-4xl mx-auto mt-4 px-4">
      <div class="bg-green-50 border border-green-300 text-green-800 px-4 py-3 rounded-lg">
        <%= success %>
      </div>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="max-w-4xl mx-auto mt-4 px-4">
      <div class="bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-lg">
        <%= error %>
      </div>
    </div>
  <% } %>

  <!-- Content -->
  <main class="flex-1 max-w-6xl mx-auto w-full px-4 py-8">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="bg-mar-oscuro text-white/70 text-center text-sm py-6 mt-auto">
    <p>&copy; <%= new Date().getFullYear() %> Galizano Reusa &mdash; Economía circular en la playa</p>
  </footer>
</body>
</html>
