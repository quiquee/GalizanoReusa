<!-- Admin: Editar objeto -->
<div class="max-w-2xl mx-auto">

  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/objetos" class="text-gray-400 hover:text-mar transition p-2 rounded-lg hover:bg-gray-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <div>
      <h1 class="text-xl font-bold text-gray-900">Editar objeto</h1>
      <p class="text-sm text-gray-400 mt-0.5">Propietario: <%= objeto.owner.nombre %> (<%= objeto.owner.email %>)</p>
    </div>
  </div>

  <!-- Fotos actuales -->
  <%
    let fotos = [];
    try { fotos = JSON.parse(objeto.fotos || '[]'); } catch(e) {}
  %>
  <% if (fotos.length > 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-5">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Fotos actuales</p>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <% fotos.forEach(function(f) { %>
          <img src="<%= f %>" alt="Foto" class="w-20 h-20 object-cover rounded-lg flex-shrink-0">
        <% }); %>
      </div>
    </div>
  <% } %>

  <form method="POST" action="/admin/objetos/<%= objeto.slug %>/editar" enctype="multipart/form-data" class="space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Datos del objeto -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Información del objeto</h2>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="titulo">Título</label>
        <input id="titulo" name="titulo" type="text" value="<%= objeto.titulo %>" required
               class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="descripcion">Descripción</label>
        <textarea id="descripcion" name="descripcion" rows="4" required
                  class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none resize-none"><%= objeto.descripcion %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="tipoTransaccion">Tipo de transacción</label>
        <select id="tipoTransaccion" name="tipoTransaccion"
                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
          <option value="venta"            <%= objeto.tipoTransaccion === 'venta'            ? 'selected' : '' %>>Solo venta</option>
          <option value="alquiler_medio_dia" <%= objeto.tipoTransaccion === 'alquiler_medio_dia' ? 'selected' : '' %>>Alquiler medio día</option>
          <option value="alquiler_dia"     <%= objeto.tipoTransaccion === 'alquiler_dia'     ? 'selected' : '' %>>Alquiler día completo</option>
          <option value="ambos_alquiler"   <%= objeto.tipoTransaccion === 'ambos_alquiler'   ? 'selected' : '' %>>Ambos alquileres</option>
          <option value="todos"            <%= objeto.tipoTransaccion === 'todos'            ? 'selected' : '' %>>Todos</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="activo">Estado</label>
        <select id="activo" name="activo"
                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
          <option value="true"  <%= objeto.activo ? 'selected' : '' %>>Activo</option>
          <option value="false" <%= !objeto.activo ? 'selected' : '' %>>Desactivado</option>
        </select>
      </div>
    </div>

    <!-- Precios y fianza -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Precios y fianza</h2>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="precioVenta">Precio venta (€)</label>
          <input id="precioVenta" name="precioVenta" type="number" step="0.01" min="0"
                 value="<%= objeto.precioVenta !== null ? objeto.precioVenta : '' %>"
                 class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="precioMedioDia">Precio ½ día (€)</label>
          <input id="precioMedioDia" name="precioMedioDia" type="number" step="0.01" min="0"
                 value="<%= objeto.precioMedioDia !== null ? objeto.precioMedioDia : '' %>"
                 class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="precioDiaEntero">Precio día (€)</label>
          <input id="precioDiaEntero" name="precioDiaEntero" type="number" step="0.01" min="0"
                 value="<%= objeto.precioDiaEntero !== null ? objeto.precioDiaEntero : '' %>"
                 class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="importeFianza">Fianza (€) <span class="text-red-500">*</span></label>
          <input id="importeFianza" name="importeFianza" type="number" step="0.01" min="0"
                 value="<%= objeto.importeFianza %>" required
                 class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:ring-2 focus:ring-mar focus:outline-none">
        </div>
      </div>
    </div>

    <!-- Añadir fotos -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <label class="block text-sm font-medium text-gray-700 mb-2" for="fotos">Añadir fotos (opcional)</label>
      <input id="fotos" name="fotos" type="file" accept="image/*" multiple
             class="w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-mar/10 file:text-mar hover:file:bg-mar/20 transition">
      <p class="text-xs text-gray-400 mt-1">Las fotos se añadirán a las existentes (máx. 5 en total).</p>
    </div>

    <!-- Acciones -->
    <div class="flex gap-3">
      <button type="submit"
              class="flex-1 bg-mar text-white text-sm font-semibold py-3 rounded-xl hover:bg-mar-oscuro transition">
        Guardar cambios
      </button>
      <a href="/admin/objetos" class="flex-1 text-center border border-gray-200 text-gray-600 text-sm font-medium py-3 rounded-xl hover:bg-gray-50 transition">
        Cancelar
      </a>
    </div>
  </form>
</div>
