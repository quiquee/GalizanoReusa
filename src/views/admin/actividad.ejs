<!-- Admin: Actividad reciente -->
<div class="max-w-5xl mx-auto">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Actividad Reciente</h1>
      <p class="text-sm text-gray-500 mt-0.5">
        <%= transacciones.length %> transacción(es) — Ingresos filtrados:
        <span class="font-semibold text-mar"><%= totalIngresos.toFixed(2) %> €</span>
      </p>
    </div>
    <a href="/admin" class="text-sm text-gray-500 hover:text-mar transition">← Volver al panel</a>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/admin/actividad" class="bg-white border border-gray-100 rounded-xl shadow-sm p-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <input type="text" name="usuario" value="<%= filtros.usuario %>"
             placeholder="Filtrar por usuario…"
             class="text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:outline-none">
      <input type="text" name="objeto" value="<%= filtros.objeto %>"
             placeholder="Filtrar por objeto…"
             class="text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:outline-none">
      <select name="estado" class="text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:outline-none">
        <option value="">Todos los estados</option>
        <option value="pendiente"  <%= filtros.estado === 'pendiente'  ? 'selected' : '' %>>Pendiente</option>
        <option value="pagado"     <%= filtros.estado === 'pagado'     ? 'selected' : '' %>>Pagado</option>
        <option value="en_uso"     <%= filtros.estado === 'en_uso'     ? 'selected' : '' %>>En uso</option>
        <option value="devuelto"   <%= filtros.estado === 'devuelto'   ? 'selected' : '' %>>Devuelto</option>
        <option value="cerrado"    <%= filtros.estado === 'cerrado'    ? 'selected' : '' %>>Cerrado</option>
        <option value="incidencia" <%= filtros.estado === 'incidencia' ? 'selected' : '' %>>Incidencia</option>
      </select>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Desde</label>
        <input type="date" name="desde" value="<%= filtros.desde %>"
               class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Hasta</label>
        <input type="date" name="hasta" value="<%= filtros.hasta %>"
               class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:outline-none">
      </div>
      <div class="flex gap-2 items-end">
        <button type="submit" class="flex-1 bg-mar text-white text-sm py-2 rounded-lg hover:bg-mar-oscuro transition">Aplicar</button>
        <% if (filtros.usuario || filtros.objeto || filtros.estado || filtros.desde || filtros.hasta) { %>
          <a href="/admin/actividad" class="text-sm text-gray-500 border border-gray-200 px-3 py-2 rounded-lg hover:bg-gray-50 text-center">✕</a>
        <% } %>
      </div>
    </div>
  </form>

  <!-- Tabla de transacciones -->
  <% if (transacciones.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-10 text-center text-gray-400">
      <p class="text-4xl mb-3">📊</p>
      <p>No hay actividad que coincida con los filtros.</p>
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[680px]">
          <thead class="bg-gray-50">
            <tr class="text-left text-xs text-gray-500 uppercase tracking-wide border-b border-gray-100">
              <th class="px-4 py-3">Objeto</th>
              <th class="px-4 py-3">Cliente</th>
              <th class="px-4 py-3">Tipo</th>
              <th class="px-4 py-3">Pago</th>
              <th class="px-4 py-3">Fianza</th>
              <th class="px-4 py-3">Estado</th>
              <th class="px-4 py-3">Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% transacciones.forEach(function(txn) { %>
              <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                <td class="px-4 py-3 font-medium text-mar-oscuro truncate max-w-[140px]">
                  <a href="/o/<%= txn.item.slug %>" target="_blank" class="hover:underline"><%= txn.item.titulo %></a>
                </td>
                <td class="px-4 py-3 text-gray-600 max-w-[160px]">
                  <% if (txn.client) { %>
                    <p class="truncate font-medium"><%= txn.client.nombre %></p>
                    <p class="truncate text-xs text-gray-400"><%= txn.client.email %></p>
                  <% } else if (txn.guestEmail) { %>
                    <p class="text-xs text-gray-400 italic">Invitado</p>
                    <p class="truncate text-xs text-gray-500"><%= txn.guestEmail %></p>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 capitalize text-gray-600 whitespace-nowrap"><%= txn.tipo.replace(/_/g,' ') %></td>
                <td class="px-4 py-3 font-semibold whitespace-nowrap"><%= txn.importePago.toFixed(2) %> €</td>
                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">
                  <% if (txn.importeFianza > 0) { %>
                    <span class="<%= txn.fianzaBloqueada ? 'text-red-500' : txn.fianzaDevuelta ? 'text-green-600' : 'text-amber-500' %>">
                      <%= txn.importeFianza.toFixed(2) %> €
                      <%= txn.fianzaBloqueada ? '🔒' : txn.fianzaDevuelta ? '✓' : '' %>
                    </span>
                  <% } else { %><span class="text-gray-300">—</span><% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium whitespace-nowrap
                    <%= txn.estado === 'en_uso'    ? 'bg-amber-100 text-amber-700' :
                       txn.estado === 'pagado'     ? 'bg-blue-100 text-blue-700' :
                       txn.estado === 'devuelto'   ? 'bg-green-100 text-green-700' :
                       txn.estado === 'cerrado'    ? 'bg-gray-100 text-gray-600' :
                       txn.estado === 'incidencia' ? 'bg-red-100 text-red-700' :
                       'bg-gray-100 text-gray-500' %>">
                    <%= txn.estado %>
                  </span>
                </td>
                <td class="px-4 py-3 text-gray-400 whitespace-nowrap">
                  <%= new Date(txn.createdAt).toLocaleDateString('es-ES', { day:'2-digit', month:'short', year:'2-digit' }) %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
