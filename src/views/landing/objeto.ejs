<%# Landing page del objeto - destino del QR escaneado en playa/parking %>

<!-- Galería de fotos -->
<div class="mb-6">
  <% if (fotos.length > 0) { %>
    <img src="<%= fotos[0] %>" alt="<%= item.titulo %>" class="w-full h-56 object-cover rounded-2xl shadow-md">
    <% if (fotos.length > 1) { %>
      <div class="flex gap-2 mt-2 overflow-x-auto">
        <% fotos.forEach(function(foto, i) { %>
          <img src="<%= foto %>" alt="Foto <%= i + 1 %>" class="w-16 h-16 object-cover rounded-lg border-2 border-white shadow flex-shrink-0">
        <% }); %>
      </div>
    <% } %>
  <% } else { %>
    <div class="w-full h-56 bg-gray-200 rounded-2xl flex items-center justify-center text-4xl">📦</div>
  <% } %>
</div>

<!-- Info del objeto -->
<div class="bg-white rounded-2xl shadow-md p-5 mb-4">
  <h1 class="text-xl font-bold text-mar-oscuro mb-2"><%= item.titulo %></h1>
  <p class="text-gray-600 text-sm leading-relaxed"><%= item.descripcion %></p>
</div>

<!-- Tarifas y formulario de pago -->
<div class="bg-white rounded-2xl shadow-md p-5 mb-4">
  <h2 class="font-semibold text-gray-800 mb-3">Elige tu opción</h2>

  <form method="POST" action="/pay/crear-sesion" id="paymentForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="itemId" value="<%= item.id %>">

    <div class="space-y-2">
      <% if (['venta', 'todos'].includes(item.tipoTransaccion) && item.precioVenta) { %>
        <label class="flex items-center gap-3 p-3 border rounded-xl cursor-pointer hover:bg-sky-50 transition">
          <input type="radio" name="tipo" value="venta" required class="accent-mar w-4 h-4">
          <div class="flex-1">
            <span class="font-medium text-sm">Comprar</span>
          </div>
          <span class="font-bold text-mar"><%= item.precioVenta.toFixed(2) %> €</span>
        </label>
      <% } %>

      <% if (['alquiler_medio_dia', 'ambos_alquiler', 'todos'].includes(item.tipoTransaccion) && item.precioMedioDia) { %>
        <label class="flex items-center gap-3 p-3 border rounded-xl cursor-pointer hover:bg-sky-50 transition">
          <input type="radio" name="tipo" value="alquiler_medio_dia" required class="accent-mar w-4 h-4">
          <div class="flex-1">
            <span class="font-medium text-sm">Alquiler medio día</span>
          </div>
          <span class="font-bold text-mar"><%= item.precioMedioDia.toFixed(2) %> €</span>
        </label>
      <% } %>

      <% if (['alquiler_dia', 'ambos_alquiler', 'todos'].includes(item.tipoTransaccion) && item.precioDiaEntero) { %>
        <label class="flex items-center gap-3 p-3 border rounded-xl cursor-pointer hover:bg-sky-50 transition">
          <input type="radio" name="tipo" value="alquiler_dia" required class="accent-mar w-4 h-4">
          <div class="flex-1">
            <span class="font-medium text-sm">Alquiler día entero</span>
          </div>
          <span class="font-bold text-mar"><%= item.precioDiaEntero.toFixed(2) %> €</span>
        </label>
      <% } %>
    </div>

    <!-- Info fianza -->
    <% if (cobraFianza) { %>
      <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg p-3">
        <p class="text-xs text-amber-800">
          <strong>⚠️ Fianza reembolsable:</strong> <%= item.importeFianza.toFixed(2) %> €<br>
          Al no estar registrado, se cobrará una fianza adicional que se devolverá al día siguiente si el objeto se devuelve en buenas condiciones.
        </p>
        <a href="/auth/registro-cliente" class="text-xs text-mar font-medium hover:underline block mt-2">
          → Regístrate para no pagar fianza
        </a>
      </div>
    <% } else { %>
      <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-3">
        <p class="text-xs text-green-800">
          ✅ <strong>Usuario verificado</strong> — No se te cobrará fianza.
        </p>
      </div>
    <% } %>

    <button type="submit"
      class="w-full mt-4 bg-mar text-white py-3 rounded-xl font-semibold text-lg hover:bg-mar-oscuro transition shadow-lg">
      💳 Pagar con tarjeta
    </button>
  </form>
</div>

<!-- Opciones de registro rápido para invitados -->
<% if (!isRegistered) { %>
  <div class="bg-white rounded-2xl shadow-md p-5 mb-4">
    <h3 class="font-semibold text-gray-800 mb-2 text-sm">¿Quieres evitar la fianza?</h3>
    <p class="text-xs text-gray-500 mb-3">
      Crea una cuenta con tu Nombre, Dirección, DNI y verifica tu email. Los usuarios registrados no pagan fianza.
    </p>
    <div class="flex gap-2">
      <a href="/auth/registro-cliente" class="flex-1 text-center bg-verde/10 text-verde py-2 rounded-lg text-sm font-medium hover:bg-verde/20 transition">
        Registrarme
      </a>
      <a href="/auth/login" class="flex-1 text-center bg-gray-100 text-gray-600 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition">
        Ya tengo cuenta
      </a>
    </div>
  </div>
<% } %>

<p class="text-center text-xs text-gray-400 mt-4">
  Pago seguro procesado por Stripe. Al finalizar, devuelve el objeto en el mismo lugar.
</p>
