<div class="max-w-md mx-auto text-center">
  <h1 class="text-2xl font-bold text-mar-oscuro mb-2">Código QR generado</h1>
  <p class="text-gray-600 mb-6">Imprime este QR y colócalo junto a tu objeto: <strong><%= item.titulo %></strong></p>

  <div class="bg-white rounded-2xl shadow-md p-8 inline-block">
    <% if (item.qrCode) { %>
      <img src="<%= item.qrCode %>" alt="QR de <%= item.titulo %>" class="w-64 h-64 mx-auto">
    <% } %>
    <p class="text-xs text-gray-400 mt-4 font-mono break-all"><%= baseUrl %>/o/<%= item.slug %></p>
  </div>

  <div class="mt-6 flex gap-3 justify-center">
    <button onclick="window.print()" class="bg-mar text-white px-4 py-2 rounded-lg hover:bg-mar-oscuro transition text-sm">
      🖨️ Imprimir QR
    </button>
    <a href="/dashboard" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition text-sm">
      Volver al panel
    </a>
  </div>
</div>

<style>
  @media print {
    nav, footer, button, a[href="/dashboard"] { display: none !important; }
    body { background: white !important; }
    main { padding: 0 !important; }
  }
</style>
