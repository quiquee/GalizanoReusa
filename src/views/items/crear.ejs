<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-mar-oscuro mb-6">Añadir Objeto</h1>

  <form method="POST" action="/items/crear" enctype="multipart/form-data" class="bg-white rounded-2xl shadow-md p-6 space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Fotos -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Fotografías del objeto * (máx. 5)</label>
      <input type="file" name="fotos" multiple accept="image/jpeg,image/png,image/webp" required
        class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-mar/10 file:text-mar file:font-medium hover:file:bg-mar/20 file:cursor-pointer">
    </div>

    <!-- Título -->
    <div>
      <label for="titulo" class="block text-sm font-medium text-gray-700 mb-1">Título *</label>
      <input type="text" id="titulo" name="titulo" required minlength="2" maxlength="100"
        placeholder="Ej: Tabla de surf 6 pies"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
    </div>

    <!-- Descripción -->
    <div>
      <label for="descripcion" class="block text-sm font-medium text-gray-700 mb-1">Descripción *</label>
      <textarea id="descripcion" name="descripcion" rows="3" required minlength="5" maxlength="1000"
        placeholder="Describe tu objeto: estado, características, instrucciones de uso..."
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none resize-y"></textarea>
    </div>

    <!-- Tipo de transacción -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Modelo de negocio *</label>
      <select id="tipoTransaccion" name="tipoTransaccion" required
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none"
        onchange="togglePriceFields()">
        <option value="">Selecciona...</option>
        <option value="venta">Solo venta</option>
        <option value="alquiler_medio_dia">Alquiler medio día</option>
        <option value="alquiler_dia">Alquiler día entero</option>
        <option value="ambos_alquiler">Alquiler (medio día + día entero)</option>
        <option value="todos">Venta + Alquiler (todas las opciones)</option>
      </select>
    </div>

    <!-- Precios dinámicos -->
    <div id="precioVentaGroup" class="hidden">
      <label for="precioVenta" class="block text-sm font-medium text-gray-700 mb-1">Precio de venta (€) *</label>
      <input type="number" id="precioVenta" name="precioVenta" step="0.01" min="0.01"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
    </div>

    <div id="precioMedioDiaGroup" class="hidden">
      <label for="precioMedioDia" class="block text-sm font-medium text-gray-700 mb-1">Precio alquiler medio día (€) *</label>
      <input type="number" id="precioMedioDia" name="precioMedioDia" step="0.01" min="0.01"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
    </div>

    <div id="precioDiaEnteroGroup" class="hidden">
      <label for="precioDiaEntero" class="block text-sm font-medium text-gray-700 mb-1">Precio alquiler día entero (€) *</label>
      <input type="number" id="precioDiaEntero" name="precioDiaEntero" step="0.01" min="0.01"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
    </div>

    <!-- Fianza -->
    <div>
      <label for="importeFianza" class="block text-sm font-medium text-gray-700 mb-1">Importe de fianza (€) *</label>
      <input type="number" id="importeFianza" name="importeFianza" step="0.01" min="0.01" required
        placeholder="Ej: 20.00"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      <p class="text-xs text-gray-400 mt-1">Se cobra solo a usuarios no registrados. Protege tu objeto en caso de robo o daño.</p>
    </div>

    <button type="submit"
      class="w-full bg-mar text-white py-2.5 rounded-lg font-medium hover:bg-mar-oscuro transition">
      Crear objeto y generar QR
    </button>
  </form>
</div>

<script>
function togglePriceFields() {
  const tipo = document.getElementById('tipoTransaccion').value;
  const venta = document.getElementById('precioVentaGroup');
  const medioDia = document.getElementById('precioMedioDiaGroup');
  const diaEntero = document.getElementById('precioDiaEnteroGroup');

  venta.classList.add('hidden');
  medioDia.classList.add('hidden');
  diaEntero.classList.add('hidden');

  if (tipo === 'venta' || tipo === 'todos') venta.classList.remove('hidden');
  if (tipo === 'alquiler_medio_dia' || tipo === 'ambos_alquiler' || tipo === 'todos') medioDia.classList.remove('hidden');
  if (tipo === 'alquiler_dia' || tipo === 'ambos_alquiler' || tipo === 'todos') diaEntero.classList.remove('hidden');
}
</script>
