<div class="max-w-md mx-auto">
  <% if (user) { %>
    <%# Usuario ya logueado → formulario reducido (upgrade a ofertante) %>
    <h1 class="text-2xl font-bold text-mar-oscuro mb-2 text-center">Convertirme en Ofertante</h1>
    <p class="text-sm text-gray-500 text-center mb-6">
      <strong><%= user.nombre %></strong>, solo necesitamos tu cuenta bancaria y DNI para activarte como ofertante. Tu identidad será <strong>siempre anónima</strong> para los clientes.
    </p>

    <form method="POST" action="/auth/upgrade-ofertante" class="bg-white rounded-2xl shadow-md p-6 space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="bankIban" class="block text-sm font-medium text-gray-700 mb-1">IBAN de tu cuenta bancaria *</label>
        <input type="text" id="bankIban" name="bankIban" required minlength="15" maxlength="34"
          placeholder="ES12 0000 0000 0000 0000 0000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none font-mono">
        <p class="text-xs text-gray-400 mt-1">Necesario para transferirte los ingresos generados</p>
      </div>

      <% if (!user.dni) { %>
        <div>
          <label for="dni" class="block text-sm font-medium text-gray-700 mb-1">DNI / NIE *</label>
          <input type="text" id="dni" name="dni" required minlength="9" maxlength="20" placeholder="12345678A"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
        </div>
      <% } %>

      <button type="submit"
        class="w-full bg-verde text-white py-2.5 rounded-lg font-medium hover:bg-green-800 transition">
        Activar cuenta de ofertante
      </button>
    </form>

  <% } else { %>
    <%# Usuario no logueado → formulario completo %>
    <h1 class="text-2xl font-bold text-mar-oscuro mb-2 text-center">Registro de Ofertante</h1>
    <p class="text-sm text-gray-500 text-center mb-6">
      Registra tu cuenta para subir objetos y recibir ingresos. Tu identidad será <strong>siempre anónima</strong> para los clientes.
    </p>

    <form method="POST" action="/auth/registro-ofertante" class="bg-white rounded-2xl shadow-md p-6 space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre completo *</label>
        <input type="text" id="nombre" name="nombre" required minlength="2" maxlength="100"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña * (mín. 8 caracteres)</label>
        <input type="password" id="password" name="password" required minlength="8" autocomplete="new-password"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="bankIban" class="block text-sm font-medium text-gray-700 mb-1">IBAN de tu cuenta bancaria *</label>
        <input type="text" id="bankIban" name="bankIban" required minlength="15" maxlength="34"
          placeholder="ES12 0000 0000 0000 0000 0000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none font-mono">
        <p class="text-xs text-gray-400 mt-1">Necesario para transferirte los ingresos generados</p>
      </div>

      <button type="submit"
        class="w-full bg-verde text-white py-2.5 rounded-lg font-medium hover:bg-green-800 transition">
        Crear cuenta de ofertante
      </button>
    </form>

    <p class="mt-4 text-center text-sm text-gray-500">
      ¿Ya tienes cuenta? <a href="/auth/login" class="text-mar hover:underline">Inicia sesión</a>
    </p>
  <% } %>
</div>
