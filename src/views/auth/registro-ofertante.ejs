<div class="max-w-md mx-auto">
  <div class="flex justify-center mb-4">
    <img src="/images/GalizanoReusa-Icon.jpeg" alt="<%= t('brand') %>" class="w-16 h-16 rounded-full object-cover shadow-md">
  </div>
  <% if (user) { %>
    <h1 class="text-2xl font-bold text-mar-oscuro mb-2 text-center"><%= t('auth.upgradeTitle') %></h1>
    <p class="text-sm text-gray-500 text-center mb-6"><%- t('auth.upgradeDesc', { name: user.nombre }) %></p>

    <form method="POST" action="/auth/upgrade-ofertante" class="bg-white rounded-2xl shadow-md p-6 space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="bankIban" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.ibanLabel') %></label>
        <input type="text" id="bankIban" name="bankIban" required minlength="15" maxlength="34"
          placeholder="ES12 0000 0000 0000 0000 0000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none font-mono">
        <p class="text-xs text-gray-400 mt-1"><%= t('auth.ibanHelper') %></p>
      </div>

      <% if (!user.dni) { %>
        <div>
          <label for="dni" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.dniLabel') %></label>
          <input type="text" id="dni" name="dni" required minlength="9" maxlength="20" placeholder="12345678A"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
        </div>
      <% } %>

      <button type="submit"
        class="w-full bg-verde text-white py-2.5 rounded-lg font-medium hover:bg-green-800 transition">
        <%= t('auth.activateOfertante') %>
      </button>
    </form>

  <% } else { %>
    <h1 class="text-2xl font-bold text-mar-oscuro mb-2 text-center"><%= t('auth.ofertanteRegTitle') %></h1>
    <p class="text-sm text-gray-500 text-center mb-6"><%- t('auth.ofertanteRegDesc') %></p>

    <form method="POST" action="/auth/registro-ofertante" class="bg-white rounded-2xl shadow-md p-6 space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.fullName') %></label>
        <input type="text" id="nombre" name="nombre" required minlength="2" maxlength="100"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.emailRequired') %></label>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.passwordLabel') %></label>
        <input type="password" id="password" name="password" required minlength="8" autocomplete="new-password"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none">
      </div>

      <div>
        <label for="bankIban" class="block text-sm font-medium text-gray-700 mb-1"><%= t('auth.ibanLabel') %></label>
        <input type="text" id="bankIban" name="bankIban" required minlength="15" maxlength="34"
          placeholder="ES12 0000 0000 0000 0000 0000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-mar focus:border-transparent outline-none font-mono">
        <p class="text-xs text-gray-400 mt-1"><%= t('auth.ibanHelper') %></p>
      </div>

      <button type="submit"
        class="w-full bg-verde text-white py-2.5 rounded-lg font-medium hover:bg-green-800 transition">
        <%= t('auth.createOfertanteAccount') %>
      </button>
    </form>

    <p class="mt-4 text-center text-sm text-gray-500">
      <%= t('auth.alreadyHaveAccount') %> <a href="/auth/login" class="text-mar hover:underline"><%= t('auth.loginLink') %></a>
    </p>
  <% } %>
</div>
