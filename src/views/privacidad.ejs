<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold text-mar-oscuro mb-6"><%= t('privacy.title') %></h1>

  <div class="bg-white rounded-2xl shadow-md p-8 space-y-6 text-gray-700 text-sm leading-relaxed">

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section1Title') %></h2>
      <p><%- t('privacy.section1Text') %></p>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section2Title') %></h2>
      <p><%= t('privacy.section2Intro') %></p>
      <ul class="list-disc ml-6 mt-2 space-y-1">
        <% t('privacy.section2Items', { returnObjects: true }).forEach(function(item) { %>
          <li><%= item %></li>
        <% }); %>
      </ul>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section3Title') %></h2>
      <p><%= t('privacy.section3Intro') %></p>
      <ul class="list-disc ml-6 mt-2 space-y-1">
        <% t('privacy.section3Items', { returnObjects: true }).forEach(function(item) { %>
          <li><%= item %></li>
        <% }); %>
      </ul>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section4Title') %></h2>
      <p><%= t('privacy.section4Text') %></p>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section5Title') %></h2>
      <p><%= t('privacy.section5Intro') %></p>
      <ul class="list-disc ml-6 mt-2 space-y-1">
        <% t('privacy.section5Items', { returnObjects: true }).forEach(function(item) { %>
          <li><%- item %></li>
        <% }); %>
      </ul>
    </section>

    <section class="bg-sky-50 border border-sky-200 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section6Title') %></h2>
      <p><%- t('privacy.section6Text1') %></p>
      <p class="mt-3 text-center">
        <a href="mailto:privacy@hcpartners.ch"
          class="inline-block bg-mar text-white px-6 py-3 rounded-lg font-medium hover:bg-mar-oscuro transition text-base">
          📧 privacy@hcpartners.ch
        </a>
      </p>
      <p class="mt-3"><%- t('privacy.section6Text2') %></p>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section7Title') %></h2>
      <p><%= t('privacy.section7Text') %></p>
    </section>

    <section>
      <h2 class="text-lg font-semibold text-mar-oscuro mb-2"><%= t('privacy.section8Title') %></h2>
      <p><%- t('privacy.section8Text') %></p>
    </section>

    <p class="text-xs text-gray-400 text-right"><%= t('privacy.lastUpdate') %></p>
  </div>
</div>
