<h1 class="text-2xl font-bold text-mar-oscuro mb-6">Mi Panel de Ofertante</h1>

<!-- Resumen rápido -->
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <p class="text-2xl font-bold text-mar"><%= items.length %></p>
    <p class="text-xs text-gray-500">Objetos</p>
  </div>
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <p class="text-2xl font-bold text-verde"><%= items.filter(i => i.activo).length %></p>
    <p class="text-xs text-gray-500">Activos</p>
  </div>
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <p class="text-2xl font-bold text-amber-500"><%= activeTransactions.filter(t => t.estado === 'en_uso').length %></p>
    <p class="text-xs text-gray-500">En uso</p>
  </div>
</div>

<!-- Acciones -->
<div class="flex gap-3 mb-6">
  <a href="/items/crear" class="bg-mar text-white px-4 py-2 rounded-lg hover:bg-mar-oscuro transition text-sm font-medium">
    + Añadir objeto
  </a>
  <a href="/dashboard/devoluciones" class="bg-amber-100 text-amber-800 px-4 py-2 rounded-lg hover:bg-amber-200 transition text-sm font-medium">
    📋 Devoluciones
  </a>
</div>

<!-- Mis objetos -->
<h2 class="text-lg font-semibold text-gray-800 mb-3">Mis Objetos</h2>

<% if (items.length === 0) { %>
  <div class="bg-white rounded-xl shadow p-8 text-center text-gray-400">
    <p class="text-4xl mb-3">📦</p>
    <p>Aún no has subido ningún objeto.</p>
    <a href="/items/crear" class="text-mar hover:underline text-sm mt-2 inline-block">Subir mi primer objeto</a>
  </div>
<% } else { %>
  <div class="grid md:grid-cols-2 gap-4">
    <% items.forEach(function(item) { %>
      <div class="bg-white rounded-xl shadow p-4 flex gap-4 <%= !item.activo ? 'opacity-60' : '' %>">
        <% const fotos = JSON.parse(item.fotos || '[]'); %>
        <% if (fotos.length > 0) { %>
          <img src="<%= fotos[0] %>" alt="<%= item.titulo %>" class="w-20 h-20 object-cover rounded-lg flex-shrink-0">
        <% } else { %>
          <div class="w-20 h-20 bg-gray-100 rounded-lg flex items-center justify-center text-2xl flex-shrink-0">📦</div>
        <% } %>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-sm text-mar-oscuro truncate"><%= item.titulo %></h3>
          <p class="text-xs text-gray-500 mt-1">
            Fianza: <%= item.importeFianza.toFixed(2) %> €
            <% if (!item.activo) { %><span class="text-red-500 font-medium"> — Desactivado</span><% } %>
          </p>
          <div class="flex gap-2 mt-2">
            <a href="/items/<%= item.slug %>/qr" class="text-xs bg-mar/10 text-mar px-2 py-1 rounded hover:bg-mar/20">QR</a>
            <a href="/items/<%= item.slug %>/editar" class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded hover:bg-gray-200">Editar</a>
            <form method="POST" action="/items/<%= item.slug %>/desactivar" class="inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded hover:bg-gray-200">
                <%= item.activo ? 'Desactivar' : 'Activar' %>
              </button>
            </form>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<!-- Transacciones activas -->
<% if (activeTransactions.length > 0) { %>
  <h2 class="text-lg font-semibold text-gray-800 mb-3 mt-8">Transacciones Recientes</h2>
  <div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600">
        <tr>
          <th class="text-left px-4 py-2">Objeto</th>
          <th class="text-left px-4 py-2">Tipo</th>
          <th class="text-left px-4 py-2">Importe</th>
          <th class="text-left px-4 py-2">Estado</th>
        </tr>
      </thead>
      <tbody>
        <% activeTransactions.forEach(function(txn) { %>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2"><%= txn.item.titulo %></td>
            <td class="px-4 py-2 capitalize"><%= txn.tipo.replace(/_/g, ' ') %></td>
            <td class="px-4 py-2"><%= txn.importePago.toFixed(2) %> €</td>
            <td class="px-4 py-2">
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium
                <%= txn.estado === 'en_uso' ? 'bg-amber-100 text-amber-700' :
                   txn.estado === 'pagado' ? 'bg-blue-100 text-blue-700' :
                   txn.estado === 'devuelto' ? 'bg-green-100 text-green-700' :
                   txn.estado === 'incidencia' ? 'bg-red-100 text-red-700' :
                   'bg-gray-100 text-gray-700' %>">
                <%= txn.estado %>
              </span>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
