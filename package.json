{
  "name": "galizano-reusa",
  "version": "1.0.0",
  "description": "Plataforma de economía circular para reutilización de objetos en zonas de playa - Galizano Reusa",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "css:build": "tailwindcss -i src/styles/input.css -o public/css/style.css --minify",
    "css:watch": "tailwindcss -i src/styles/input.css -o public/css/style.css --watch",
    "build": "npm run css:build",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "keywords": [
    "circular-economy",
    "qr-rental",
    "beach",
    "galizano"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "i18next": "^26.0.1",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "stripe": "^17.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.2.2"
  }
}
